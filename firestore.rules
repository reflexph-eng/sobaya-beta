rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.globalRole == 'super_admin';
    }

    function isGlobalRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.globalRole == role;
    }

    function isOrgMember(orgId) {
      return signedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.status == 'active';
    }

    function hasPermission(orgId, permission) {
      return isOrgMember(orgId)
        && permission in get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.permissions;
    }

    function validOrgCreate(orgId) {
      return request.resource.data.organizationId == orgId;
    }

    function validOrgUpdate(orgId) {
      return resource.data.organizationId == orgId
        && request.resource.data.organizationId == orgId;
    }

    function canReadOrgData(orgId, permission) {
      return isSuperAdmin() || hasPermission(orgId, permission);
    }

    function canCreateOrgData(orgId, permission) {
      return (isSuperAdmin() || hasPermission(orgId, permission)) && validOrgCreate(orgId);
    }

    function canUpdateOrgData(orgId, permission) {
      return (isSuperAdmin() || hasPermission(orgId, permission)) && validOrgUpdate(orgId);
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
      // Un utilisateur peut modifier son propre profil. Le super_admin peut tout modifier.
      // Le platform_admin peut uniquement modifier le champ globalRole (délégation de rôles),
      // mais ne peut pas s'attribuer le rôle super_admin à lui-même.
      allow update: if signedIn() && (
        request.auth.uid == userId
        || isSuperAdmin()
        || (
          isGlobalRole("platform_admin")
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["globalRole"])
          && request.resource.data.globalRole != "super_admin"
        )
      );
      allow delete: if isSuperAdmin();

      match /consents/{consentId} {
        allow read: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
        allow create: if signedIn() && request.auth.uid == userId && request.resource.data.userId == userId;
        allow update, delete: if false;
      }
    }

    match /organizations/{orgId} {
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isSuperAdmin() || isOrgMember(orgId);
      allow update: if isSuperAdmin() || hasPermission(orgId, 'settings.manage');
      allow delete: if isSuperAdmin();

      match /members/{memberId} {
        allow read: if isSuperAdmin() || isOrgMember(orgId);
        allow create: if isSuperAdmin()
          || hasPermission(orgId, 'settings.manage')
          || (signedIn()
            && memberId == request.auth.uid
            && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid
            && request.resource.data.role == 'owner'
            && request.resource.data.status == 'active');
        allow update, delete: if isSuperAdmin() || hasPermission(orgId, 'settings.manage');
      }

      match /properties/{docId} {
        allow read: if canReadOrgData(orgId, 'properties.read');
        allow create: if canCreateOrgData(orgId, 'properties.create');
        allow update: if canUpdateOrgData(orgId, 'properties.update') || canUpdateOrgData(orgId, 'properties.delete') || canUpdateOrgData(orgId, 'archives.manage');
        allow delete: if isSuperAdmin();
      }

      match /tenants/{docId} {
        allow read: if canReadOrgData(orgId, 'tenants.read');
        allow create: if canCreateOrgData(orgId, 'tenants.create');
        allow update: if canUpdateOrgData(orgId, 'tenants.update') || canUpdateOrgData(orgId, 'archives.manage');
        allow delete: if isSuperAdmin();
      }

      match /contracts/{docId} {
        allow read: if canReadOrgData(orgId, 'contracts.read') || canReadOrgData(orgId, 'contracts.manage');
        allow create: if canCreateOrgData(orgId, 'contracts.create') || canCreateOrgData(orgId, 'contracts.manage');
        allow update: if canUpdateOrgData(orgId, 'contracts.update') || canUpdateOrgData(orgId, 'contracts.delete') || canUpdateOrgData(orgId, 'contracts.manage') || canUpdateOrgData(orgId, 'archives.manage');
        allow delete: if isSuperAdmin();
      }

      // Sprint Invitation — invitations locataires à usage unique
      match /tenantInvitations/{invId} {
        allow read: if isOrgMember(orgId) || isSuperAdmin();
        // Lecture publique complète (get + list) pour permettre la requête where("token","==",token)
        allow get, list: if true;
        allow create: if canCreateOrgData(orgId, 'tenants.create') || canCreateOrgData(orgId, 'tenants.manage');
        // Le locataire peut soumettre ses données
        allow update: if (resource.data.status == 'pending'
                        && request.resource.data.status == 'completed'
                        && request.resource.data.submittedData is map)
                      || isOrgMember(orgId) || isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      match /bookings/{docId} {
        allow read: if canReadOrgData(orgId, 'bookings.read') || canReadOrgData(orgId, 'bookings.manage');
        allow create: if canCreateOrgData(orgId, 'bookings.create') || canCreateOrgData(orgId, 'bookings.manage')
          // Sprint 11.2 — exception strictement limitée : un visiteur anonyme de la marketplace
          // peut créer UNE demande de réservation, jamais autre chose. Le statut doit être "pending"
          // (jamais confirmé directement par un visiteur non authentifié) et la source doit être
          // marquée explicitement, pour distinguer ces demandes des réservations créées en back-office.
          || (request.resource.data.organizationId == orgId
              && request.resource.data.status == 'pending'
              && request.resource.data.source == 'marketplace'
              && request.resource.data.guestName is string
              && request.resource.data.guestPhone is string
              && request.resource.data.propertyId is string);
        allow update: if canUpdateOrgData(orgId, 'bookings.update') || canUpdateOrgData(orgId, 'bookings.delete') || canUpdateOrgData(orgId, 'bookings.manage') || canUpdateOrgData(orgId, 'archives.manage');
        allow delete: if isSuperAdmin();
      }

      match /payments/{docId} {
        allow read: if canReadOrgData(orgId, 'payments.read') || canReadOrgData(orgId, 'payments.manage');
        allow create: if canCreateOrgData(orgId, 'payments.create') || canCreateOrgData(orgId, 'payments.manage');
        allow update: if canUpdateOrgData(orgId, 'payments.update') || canUpdateOrgData(orgId, 'payments.delete') || canUpdateOrgData(orgId, 'payments.manage') || canUpdateOrgData(orgId, 'archives.manage');
        allow delete: if isSuperAdmin();
      }

      match /maintenanceTickets/{docId} {
        allow read: if isSuperAdmin() || hasPermission(orgId, 'maintenance.manage');
        allow create: if canCreateOrgData(orgId, 'maintenance.manage');
        allow update: if canUpdateOrgData(orgId, 'maintenance.manage');
        allow delete: if isSuperAdmin();
      }


      match /maintenanceLogs/{docId} {
        allow read: if isSuperAdmin() || hasPermission(orgId, 'maintenance.manage');
        allow create: if canCreateOrgData(orgId, 'maintenance.manage');
        allow update, delete: if isSuperAdmin();
      }



      match /serviceProviders/{docId} {
        allow read: if isSuperAdmin() || hasPermission(orgId, 'providers.view') || hasPermission(orgId, 'providers.manage') || hasPermission(orgId, 'maintenance.manage');
        allow create: if ((isSuperAdmin() || hasPermission(orgId, 'providers.manage') || hasPermission(orgId, 'maintenance.manage')) && validOrgCreate(orgId));
        allow update: if ((isSuperAdmin() || hasPermission(orgId, 'providers.manage') || hasPermission(orgId, 'maintenance.manage')) && validOrgUpdate(orgId));
        allow delete: if isSuperAdmin();
      }

      match /maintenanceInterventions/{docId} {
        allow read: if isSuperAdmin() || hasPermission(orgId, 'interventions.view') || hasPermission(orgId, 'interventions.manage') || hasPermission(orgId, 'maintenance.manage');
        allow create: if ((isSuperAdmin() || hasPermission(orgId, 'interventions.manage') || hasPermission(orgId, 'maintenance.manage')) && validOrgCreate(orgId));
        allow update: if ((isSuperAdmin() || hasPermission(orgId, 'interventions.manage') || hasPermission(orgId, 'maintenance.manage')) && validOrgUpdate(orgId));
        allow delete: if isSuperAdmin();
      }

      match /documents/{docId} {
        allow read: if isSuperAdmin() || hasPermission(orgId, 'documents.manage');
        allow create: if canCreateOrgData(orgId, 'documents.manage');
        allow update: if canUpdateOrgData(orgId, 'documents.manage');
        allow delete: if isSuperAdmin();
      }

      // Sprint 10.4.0 — structure posée en avance, sans interface utilisable avant le Sprint 11.0 (marketplace).
      match /listingReports/{docId} {
        allow read: if isSuperAdmin() || hasPermission(orgId, 'settings.manage');
        // Un signalement peut être créé par un visiteur non authentifié de la marketplace (Sprint 11.0) ;
        // la validation stricte du contenu se fera à l'implémentation de cette fonctionnalité.
        allow create: if true;
        allow update: if isSuperAdmin() || hasPermission(orgId, 'settings.manage');
        allow delete: if isSuperAdmin();
      }

      // Sprint 10.4.0 — structure posée en avance pour les badges de confiance (Phases 2/3).
      // Attribution strictement réservée au super admin tant que l'automatisation n'existe pas.
      match /badges/{docId} {
        allow read: if true;
        allow create, update, delete: if isSuperAdmin();
      }


      match /notifications/{docId} {
        allow read: if isSuperAdmin() || hasPermission(orgId, 'notifications.view') || hasPermission(orgId, 'notifications.manage') || isOrgMember(orgId);
        allow create: if ((isSuperAdmin() || hasPermission(orgId, 'notifications.manage') || isOrgMember(orgId)) && validOrgCreate(orgId));
        allow update: if ((isSuperAdmin() || hasPermission(orgId, 'notifications.manage') || isOrgMember(orgId)) && validOrgUpdate(orgId));
        allow delete: if isSuperAdmin();
      }

      match /activityLogs/{docId} {
        allow read: if isSuperAdmin() || isOrgMember(orgId);
        allow create: if (isSuperAdmin() || isOrgMember(orgId)) && validOrgCreate(orgId);
        allow update, delete: if false;
      }
    }


    match /subscriptions/{organizationId} {
      allow read, write: if isSuperAdmin();
    }

    match /publicReceipts/{receiptNumber} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.receiptNumber == receiptNumber
        && request.resource.data.organizationId is string
        && (isSuperAdmin() || isOrgMember(request.resource.data.organizationId));
      allow update: if signedIn()
        && resource.data.receiptNumber == receiptNumber
        && request.resource.data.receiptNumber == receiptNumber
        && resource.data.organizationId == request.resource.data.organizationId
        && (isSuperAdmin() || isOrgMember(request.resource.data.organizationId));
      allow delete: if isSuperAdmin();
    }

    // Page Contact — soumissions publiques
    match /contactRequests/{docId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin();
    }

    // Sprint Admin — configuration globale des modules.
    match /platformConfig/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Sprint 11.3 — espaces publicitaires de la marketplace.
    // Lecture publique totale (les visiteurs doivent voir les pubs).
    // Écriture réservée au super admin uniquement.
    match /adSpots/{slotId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.organizationId is string
        && (isSuperAdmin() || hasPermission(request.resource.data.organizationId, 'properties.update'));
      // Seul le statut isActive et updatedAt peuvent changer après publication — pas de réécriture du contenu
      // via cette règle simplifiée ; une vraie édition repasse par une nouvelle publication côté service.
      allow update: if signedIn()
        && resource.data.organizationId == request.resource.data.organizationId
        && (isSuperAdmin() || hasPermission(resource.data.organizationId, 'properties.update'));
      allow delete: if isSuperAdmin();
    }

    match /listingContactRequests/{requestId} {
      // Un visiteur anonyme doit pouvoir envoyer une demande de contact sans être connecté.
      allow create: if request.resource.data.organizationId is string
        && request.resource.data.listingId is string
        && request.resource.data.visitorName is string
        && request.resource.data.visitorPhone is string;
      allow read: if isSuperAdmin() || (signedIn() && hasPermission(resource.data.organizationId, 'properties.read'));
      allow update: if isSuperAdmin() || (signedIn() && hasPermission(resource.data.organizationId, 'properties.update'));
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
